@model ParkHub.Models.ParkingIndexViewModel
@{
    ViewData["Title"] = "Parking Index";
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-1">@Model.SelectedArea</h2>
            <p class="text-muted mb-0">Browse available parking spaces and start a reservation.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="UserHome">Back to Areas</a>
            <a class="btn btn-primary" asp-action="ReservationHistory" asp-controller="Parking">My Reservations</a>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var space in Model.ParkingSpaces)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="card-title mb-1">@space.AreaName - @space.SpaceNumber</h5>
                                <p class="text-muted small mb-0">ParkingSpaceId: @space.ParkingSpaceId</p>
                            </div>
                            <span class="badge @(space.Status ? "bg-danger" : "bg-success")">@(space.Status ? "Reserved" : "Available")</span>
                        </div>
                        <p class="card-text text-muted">Status uses the `Status` field from the ParkingSpace model.</p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 pt-0">
                        <a class="btn btn-sm btn-outline-primary w-100" asp-action="Reserve" asp-route-id="@space.ParkingSpaceId" asp-controller="Parking">Reserve this space</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
