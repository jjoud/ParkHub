@model ParkHub.Models.VehicleListViewModel
@{
    ViewData["Title"] = "My Vehicles";
}

<div class="container-fluid py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">My Vehicles</h1>
            <p class="text-muted mb-0">Manage your vehicle fleet for faster reservations.</p>
        </div>
        <a class="btn btn-primary btn-lg" asp-action="CreateVehicle" asp-controller="Parking">Add New Vehicle</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>PlateNumber</th>
                            <th>VehicleType</th>
                            <th>Color</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Vehicles.Any())
                        {
                            @foreach (var vehicle in Model.Vehicles)
                            {
                                <tr>
                                    <td>@vehicle.PlateNumber</td>
                                    <td>@vehicle.VehicleType</td>
                                    <td>@vehicle.Color</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary me-2" asp-action="EditVehicle" asp-route-id="@vehicle.VehicleId" asp-controller="Parking">Edit</a>
                                        <a class="btn btn-sm btn-outline-danger" asp-action="DeleteVehicle" asp-route-id="@vehicle.VehicleId" asp-controller="Parking">Delete</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No vehicles registered yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
