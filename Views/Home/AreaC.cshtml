@{
    ViewData["Title"] = "Area C";
}

<div class="area-detail-page">
    <div class="area-detail-card">
        <h1>Area C</h1>
        <p>Select an available parking spot in this area.</p>
        <div class="slot-grid">
            @for (int i = 1; i <= 10; i++)
            {
                <div class="slot-card">C@(i)</div>
            }
        </div>
    </div>
</div>
