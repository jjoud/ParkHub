@{
    ViewData["Title"] = "Dashboard";
}

<div class="user-home-page">
    <div class="user-home-header">
        <div>
            <p class="eyebrow">Welcome back</p>
            <h1>Choose your parking area</h1>
            <p class="text-muted">Select one of the available zones to view details and continue your booking.</p>
        </div>
    </div>

    <div class="area-grid">
        <a href="/Home/AreaA" class="area-card">
            <h3>Area A</h3>
            <p>Premium parking with quick access and nearby facilities.</p>
        </a>
        <a href="/Home/AreaB" class="area-card">
            <h3>Area B</h3>
            <p>Convenient parking for daily visits and short stays.</p>
        </a>
        <a href="/Home/AreaC" class="area-card">
            <h3>Area C</h3>
            <p>Comfortable parking with wider spaces and easy entry.</p>
        </a>
        <a href="/Home/AreaD" class="area-card">
            <h3>Area D</h3>
            <p>Ideal for longer stays with calm and organized parking.</p>
        </a>
    </div>
</div>
