@{
    ViewData["Title"] = "Contact ParkHub";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <h1 class="display-6 fw-bold mb-3">Contact ParkHub</h1>
                    <p class="text-muted mb-4">Have a question or need support? Reach out and our team will respond promptly.</p>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="border rounded p-4 h-100">
                                <h5>Office</h5>
                                <p class="mb-1 text-muted">123 SmartPark Ave</p>
                                <p class="mb-0 text-muted">City Center, Suite 100</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-4 h-100">
                                <h5>Support</h5>
                                <p class="mb-1 text-muted">support@parkhub.com</p>
                                <p class="mb-0 text-muted">+1 (800) 555-0199</p>
                            </div>
                        </div>
                    </div>

                    <form>
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" placeholder="Your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" placeholder="Your email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" rows="5" placeholder="How can we help?"></textarea>
                        </div>
                        <button class="btn btn-primary btn-lg">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
