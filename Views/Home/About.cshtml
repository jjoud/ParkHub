@{
    ViewData["Title"] = "About ParkHub";
}

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h1 class="display-4 fw-bold text-purple">About ParkHub</h1>
            <p class="lead">ParkHub is a specialized parking management system engineered to automate space reservation and monitoring through a robust, scalable architecture.</p>
            
            <div class="row g-4 mt-4">
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #efe2ff !important;">
                        <div class="card-body">
                            <h5 class="card-title text-purple">Cohort Isolation</h5>
                            <p class="card-text">Utilizing advanced architectural design to ensure data isolation, security, and organized management across different parking areas.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #efe2ff !important;">
                        <div class="card-body">
                            <h5 class="card-title text-purple">Smart Reservations</h5>
                            <p class="card-text">Seamless workflow to manage the reservation lifecycle—from selecting available ParkingSpace based on AreaName to confirming booking status.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #efe2ff !important;">
                        <div class="card-body">
                            <h5 class="card-title text-purple">Integrated Payments</h5>
                            <p class="card-text">Secure and transparent payment tracking, automatically calculating TotalPrice based on duration and updating PaymentStatus instantly.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #efe2ff !important;">
                        <div class="card-body">
                            <h5 class="card-title text-purple">Full Control</h5>
                            <p class="card-text">Comprehensive dashboards for instructors and admins to monitor system activity, while providing users with full history tracking.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card border-0 shadow-lg">
                <img src="https://pub-4fc6abf6ad7c45c78a8359ce90cde2eb.r2.dev/images/watermarkeac79a27fa1327adafe3b8390194121c.jpg" class="card-img-top" alt="Parking management" />
                <div class="card-body">
                    <p class="text-muted small">ParkHub: Built for efficiency, managed with precision.</p>
                </div>
            </div>
        </div>
    </div>
</div>