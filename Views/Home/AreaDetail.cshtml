@model ParkHub.Models.ParkingIndexViewModel
@{
    ViewData["Title"] = Model.SelectedArea;
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-1">@Model.SelectedArea</h2>
            <p class="text-muted mb-0">Browse available parking spaces and start a reservation.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="UserHome">Back to Areas</a>
            <a class="btn btn-primary" asp-action="ReservationHistory" asp-controller="Parking">My Reservations</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card parking-summary shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">Area overview</h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                            <span>Total spaces</span>
                            <strong>@Model.ParkingSpaces.Count</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                            <span>Available</span>
                            <strong>@Model.ParkingSpaces.Count(s => !s.Status)</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                            <span>Reserved</span>
                            <strong>@Model.ParkingSpaces.Count(s => s.Status)</strong>
                        </li>
                    </ul>
                    <div class="parking-map__legend mt-4">
                        <div class="legend-item">
                            <span class="legend-swatch" style="background:#f5f5ff;border:1px solid #a8a0ff"></span>
                            Available
                        </div>
                        <div class="legend-item">
                            <span class="legend-swatch" style="background:#fef0f2;border:1px solid #ff8fa2"></span>
                            Reserved
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="parking-map">
                <div class="parking-map__spots">
                    @foreach (var space in Model.ParkingSpaces)
                    {
                        var statusClass = space.Status ? "reserved" : "available";
                        <a class="parking-space @statusClass" asp-controller="Parking" asp-action="Reserve" asp-route-id="@space.ParkingSpaceId">
                            <span>@space.SpaceNumber</span>
                            <small>@(space.Status ? "Reserved" : "Available")</small>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
